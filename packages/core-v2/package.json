{
  "name": "@grid-customizer/core-v2",
  "version": "0.2.0-alpha.0",
  "description": "Clean rewrite of @grid-customizer/core — single source of truth, per-module schema versioning, enforced dependencies.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ag-grid-community": ">=35.0.0",
    "ag-grid-enterprise": ">=35.0.0",
    "ag-grid-react": ">=35.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@grid-customizer/core": "*",
    "dexie": "^4.0.0",
    "ssf": "^0.11.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "ag-grid-community": "^35.1.0",
    "ag-grid-enterprise": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
