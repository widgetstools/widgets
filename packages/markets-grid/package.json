{
  "name": "@grid-customizer/markets-grid",
  "version": "0.1.0",
  "description": "AG-Grid wrapper with built-in customization — drop-in MarketsGrid component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "ag-grid-community": ">=35.0.0",
    "ag-grid-enterprise": ">=35.0.0",
    "ag-grid-react": ">=35.0.0"
  },
  "dependencies": {
    "@grid-customizer/core": "*"
  }
}
